{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install --no-audit --no-fund",
  "trailingSlash": false,
  "cleanUrls": true,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "http://16.176.208.7:8080/api/$1" },
    { "source": "/((?!assets/|geo/|.*\\.json|favicon\\.svg|robots\\.txt).*)", "destination": "/index.html" }
  ]
}
