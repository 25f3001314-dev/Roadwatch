# RoadWatch Admin — environment variables.
#
# Copy this file to `.env.local` for local development.
#
# VITE_API_BASE_URL is the absolute origin of the Spring Boot API.
# - Local dev:  http://localhost:8080  (matches docker-compose)
# - Production: https://api.your-domain.com  (or your AWS EC2 endpoint)
#
# Leaving this blank causes the SPA to call same-origin /api/* (only works
# when API and frontend are on the same domain).
VITE_API_BASE_URL=http://localhost:8080
