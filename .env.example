# RoadWatch backend environment variables
# Required for production or Render deployment

# Postgres database connection
SPRING_DATASOURCE_URL=jdbc:postgresql://<host>:5432/roadwatch
SPRING_DATASOURCE_USERNAME=<username>
SPRING_DATASOURCE_PASSWORD=<password>
SPRING_JPA_HIBERNATE_DDL_AUTO=update

# AI service URL
AI_SERVICE_URL=http://<ai-service-host>:8000

# Uploads and public URLs
ROADWATCH_UPLOADS_DIR=/app/uploads
ROADWATCH_PUBLIC_BASE_URL=https://<your-backend-host>

# Admin login
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# JWT secret must be at least 32 characters
JWT_SECRET=roadwatch-jwt-secret-change-me-in-production-min-32-chars
JWT_EXPIRATION_MS=86400000

# CORS origins for the admin UI
CORS_ALLOWED_ORIGINS=https://<your-ui-host>
